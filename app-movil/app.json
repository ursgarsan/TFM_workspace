{
  "expo": {
    "name": "app-movil",
    "slug": "app-movil",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "appmovil",
    "userInterfaceStyle": "automatic",
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.ursgarsan.appmovil",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0bd49bb1-0eed-4887-97d9-56a32b51d770"
      }
    }
  }
}
