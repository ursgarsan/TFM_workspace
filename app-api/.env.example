APP_NAME=app-api
APP_ENV=dev
APP_DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/app_api
DATABASE_ECHO=false
AUTO_CREATE_TABLES=true
JWT_SECRET_KEY=change-this-secret-in-env
JWT_ALGORITHM=HS256
ASSISTANT_AI_ENABLED=true
ASSISTANT_AI_PROVIDER=openai
ASSISTANT_AI_MODEL=llama3.1:8b
ASSISTANT_AI_API_KEY=ollama
ASSISTANT_AI_BASE_URL=http://localhost:11434/v1
ASSISTANT_AI_TIMEOUT_SECONDS=20
ASSISTANT_AI_TEMPERATURE=0.2
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=usuario-smtp
SMTP_PASSWORD=contrasena-smtp
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Equipo de salud
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
